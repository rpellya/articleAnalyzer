{
  "name": "article-analyzer",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "npx tsx src/main.ts ",
    "test": "echo \"Error: no test specified\" && exit 1",
    "fuzz:validator": "npm run build && npx jazzer fuzz/fuzz_validator.js --sync -- -max_total_time=60",
    "fuzz:pagerank": "npm run build && npx jazzer fuzz/fuzz_pagerank.js --sync -- -max_total_time=60",
    "lint": "npx eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "lint:security": "eslint src --ext .ts,.js --rule 'security/**' --quiet"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@jazzer.js/core": "^2.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-plugin-security": "^4.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  }
}